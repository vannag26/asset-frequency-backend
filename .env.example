# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=taf_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=asset_frequency

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_URL=redis://redis:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_64_char_random_string
# Get from Supabase dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# ── Financial Data APIs ───────────────────────────────────────────────────────
# Alpha Vantage (free tier: 25 requests/day — enough for daily updates)
# Get free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# Polygon.io (for real-time WebSocket streaming — paid plan needed)
# Get key at: https://polygon.io/
POLYGON_API_KEY=your_polygon_key_here

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Cron expression for daily update (default: 6:00 AM UTC)
DAILY_UPDATE_CRON=0 6 * * *

# ── API Config ────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
LOG_LEVEL=info
